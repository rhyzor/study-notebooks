# ============================================
# Python / Data Science .gitignore
# ============================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.egg-info/
*.egg

# Virtual environments
venv/
env/
ENV/
.venv
.env
venv/
env/
.envrc

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb_checkpoints
*.ipynb~
*.pyc
.ipynb_checkpoints/

# Jupyter Lab / Notebook extensions
.jupyter/
.jupyterlab/

# Data files (uncomment if you don't want to commit large data)
*.csv
*.tsv
*.xlsx
*.xls
*.db
*.sqlite
*.sqlite3
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
*.joblib

# Large data folders (adjust as needed)
data/
datasets/
input/
outputs/
results/
logs/
models/
checkpoints/
*.pth
*.pt
*.bin
*.onnx

# Model files (uncomment if you don't want to commit models)
*.h5
*.pkl
*.joblib
*.pt
*.pth
*.onnx
*.tflite
*.pb

# Plots and figures (optional)
figures/
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.pdf

# Reports
reports/
*.html

# Environment variables
.env
.env.local
.env.*.local

# IDE settings
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.vscode/
.idea/

